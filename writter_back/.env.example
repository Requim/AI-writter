APP_NAME=Novel Writer API
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
WORKERS=1
DATABASE_URL=postgresql+asyncpg://novel_writer:change-me@localhost:5432/novel_writer
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
JWT_SECRET=generate-a-random-value-with-at-least-32-characters
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=30
INVITATION_DAYS=7
DEFAULT_MONTHLY_GENERATION_LIMIT=30
PLATFORM_ADMIN_EMAIL=
PLATFORM_ADMIN_PASSWORD=

DEFAULT_LLM_PROVIDER=deepseek
DEFAULT_MODEL_NAME=deepseek-chat
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
LLM_TIMEOUT_SECONDS=180
LLM_MAX_RETRIES=2
WORKFLOW_TIMEOUT_SECONDS=600
SSE_HEARTBEAT_SECONDS=15
MAX_REFLECTION_LOOPS=3
REFLECTION_THRESHOLD=0.8
